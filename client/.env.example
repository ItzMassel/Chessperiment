# ─── Required for all modes ─────────────────────────────────────────
NEXT_PUBLIC_SOCKET_URL=https://chessperiment.app/chessperiment-server
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=generate-a-random-secret-here
AUTH_TRUST_HOST=true

# ─── Supabase (replaces Firebase Firestore) ─────────────────────────
# These are required for all cloud features.
# Create a Supabase project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# ─── Firebase (only for Auth — will be replaced in 2 weeks) ────────
# These are only needed for authentication until the auth provider swap.

# NextAuth / Google OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Firebase Admin (server-side) — only for auth
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_PROJECT_ID=

# Firebase Client (browser-side) — only for auth
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=

# ─── Optional services ──────────────────────────────────────────────
RESEND_API_KEY=
ADMIN_PASSWORD_HASH=
ADMIN_JWT_SECRET=
OLLAMA_API_KEY=
DEEPSEEK_API_KEY=

# ─── Vercel (only needed for Vercel deployment) ─────────────────────
VERCEL_OIDC_TOKEN=
