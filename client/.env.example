# ─── Required for all modes ─────────────────────────────────────────
NEXT_PUBLIC_SOCKET_URL=https://chessperiment.app/chessperiment-server
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=generate-a-random-secret-here
AUTH_TRUST_HOST=true

# ─── Firebase (optional — leave empty for offline-only mode) ────────
# These are only needed for accounts, cloud saves, multiplayer, and marketplace.
# When left empty, the app runs in offline-only mode with local storage.
#
# Create a Firebase project at https://console.firebase.google.com
# then enable Authentication (Google + Email/Password) and Firestore Database.

# NextAuth / Google OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Firebase Admin (server-side)
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_PROJECT_ID=

# Firebase Client (browser-side)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=

# ─── Optional services ──────────────────────────────────────────────
RESEND_API_KEY=
ADMIN_PASSWORD_HASH=
ADMIN_JWT_SECRET=
OLLAMA_API_KEY=
DEEPSEEK_API_KEY=

# ─── Vercel (only needed for Vercel deployment) ─────────────────────
VERCEL_OIDC_TOKEN=
